{
  "name": "llobosg/campeonatogoms2026",
  "description": "Campeonato de fútbol goms 2026",
  "type": "project",
  "require": {
    "php": "^8.2",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "phpoffice/phpspreadsheet": "^5.7",
    "tecnickcom/tcpdf": "^6.6",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
        "App\\": "src/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "chmod -R 755 public/uploads 2>/dev/null || true"
    ]
  },
  "license": "MIT",
  "authors": [
    {
      "name": "Luis Lobos",
      "email": "llobos@gltcomex.com"
    }
  ],
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
